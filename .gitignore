# ── Dados — NUNCA versionar dados reais ──────────────────────
data/raw/
data/processed/
data/incoming/
data/quarantine/

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/incoming/.gitkeep
!data/quarantine/.gitkeep

# Exceções: dados públicos e amostras fictícias são versionados
!data/external/
!data/samples/

# ── Modelos treinados ─────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*_metadados.json
!models/.gitkeep

# ── Saídas geradas ────────────────────────────────────────────
outputs/
!outputs/.gitkeep

# ── Logs ─────────────────────────────────────────────────────
logs/
!logs/.gitkeep

# ── Banco de dados local ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Configuração — NUNCA versionar segredos ───────────────────
.env
.env.local
.env.production
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Ambientes virtuais ────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Cobertura de testes ───────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Streamlit ─────────────────────────────────────────────────
.streamlit/secrets.toml
!.streamlit/config.toml

# ── Temporários ───────────────────────────────────────────────
*.tmp
*.bak
*.orig
